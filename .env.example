# Daedalus AI Gateway Configuration
# Copy this file to .env and fill in your values

# Optional: Port to listen on (default: 6767)
# PORT=6767

# Optional: XDG config directory for provider configurations (models, baseUrls)
# XDG_CONFIG_HOME=/path/to/config

# Optional: XDG data directory for API keys and active key index
# XDG_DATA_HOME=/path/to/data